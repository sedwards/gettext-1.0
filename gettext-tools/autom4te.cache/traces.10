         null)
           dnl JDK 1.1.X returns null.
           java_exec_version=1.1 ;;
       esac
       case "$java_exec_version" in
         1.1 | 1.2 | 1.3 | 1.4 | 1.5 | 1.6 | 1.7)
           AC_MSG_WARN([$CONF_JAVA is too old, cannot compile Java code for this old version any more])
