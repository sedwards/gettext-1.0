                            # Guess no on native Windows.
         mingw* | windows*) gl_cv_func_sleep_works="guessing no" ;;
                            # If we don't know, obey --enable-cross-guesses.
         *)                 gl_cv_func_sleep_works="$gl_cross_guess_normal" ;;
