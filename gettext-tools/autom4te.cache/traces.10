  fi

  AC_CACHE_CHECK([for unreachable in C],
    [gl_cv_c_func_unreachable],
    [AC_LINK_IFELSE(
       [AC_LANG_PROGRAM(
          [[#include <stddef.h>
          ]],
          [[unreachable ();
          ]])],
       [gl_cv_c_func_unreachable=yes],
       [gl_cv_c_func_unreachable=no])
    ])
