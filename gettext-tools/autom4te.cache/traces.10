    dnl either.
    CPPFLAGS="$gl_saved_CPPFLAGS"
    LIBICONV=
    LTLIBICONV=
  fi
  AC_SUBST([LIBICONV])
  AC_SUBST([LTLIBICONV])
])
m4trace:gnulib-m4/iconv.m4:268: -1- AC_DEFUN_ONCE([AM_ICONV], [
  AM_ICONV_LINK
