cat > darwin_shim.h <<EOF
#ifndef DARWIN_SHIM_H
#define DARWIN_SHIM_H

/* Force include the core standard structures FIRST to satisfy SDK requirements */
#include <stdio.h>
#include <stddef.h>
#include <stdlib.h>
#include <string.h>
#include <stdbool.h>
#include <fcntl.h>
#include <wchar.h>

#ifdef __cplusplus
extern "C" {
#endif

/* Missing Constants */
#ifndef GNULIB_LOCALEDIR
# define GNULIB_LOCALEDIR "/Users/sedwards/gtk/share/locale"
#endif
#ifndef O_BINARY
# define O_BINARY 0
#endif

/* Gnulib Memory Wrappers */
#ifndef _XMALLOC_SHIM_DEFINED
#define _XMALLOC_SHIM_DEFINED
static inline void *xmalloc(size_t n) { 
    void *p = malloc(n); if (!p && n) abort(); return p; 
}
static inline void *xrealloc(void *p, size_t n) { 
    void *r = realloc(p, n); if (!r && n) abort(); return r; 
}
#define XNMALLOC(n, t) ((t *) xmalloc ((n) * sizeof (t)))
#endif

/* Missing GNU Function Prototypes */
void error(int status, int errnum, const char *format, ...);
void xalloc_die(void);
char *last_component(char const *name);
const char *relocate(const char *pathname);

static inline int streq(const char *a, const char *b) { return strcmp(a, b) == 0; }
static inline int memeq(const void *a, const void *b, size_t n) { return memcmp(a, b, n) == 0; }

#ifndef __environ
# include <crt_externs.h>
# define environ (*_NSGetEnviron())
#endif

#ifdef __cplusplus
}
#endif

#endif /* DARWIN_SHIM_H */
EOF

find . -name "Makefile" -exec sed -i '' "s|^CFLAGS = |CFLAGS = -include $(pwd)\/darwin_shim.h |g" {} +

