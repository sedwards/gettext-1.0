cat >> gettext-tools/src/darwin_linker_stubs.c <<EOF

void *xmalloc(size_t n) { 
    void *p = malloc(n); if (!p && n) abort(); return p; 
}
void *xrealloc(void *p, size_t n) { 
    void *r = realloc(p, n); if (!r && n) abort(); return r; 
}
EOF

# Recompile the stubs
gcc -c gettext-tools/src/darwin_linker_stubs.c -o gettext-tools/src/darwin_linker_stubs.o

