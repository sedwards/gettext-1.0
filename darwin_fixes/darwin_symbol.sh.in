 #!/bin/bash
ROOT_DIR=$(pwd)
SRC_DIR="$ROOT_DIR/gettext-tools/src"
STUBS_O="$SRC_DIR/darwin_linker_stubs.o"

# Ensure stubs are ready
gcc -c "$SRC_DIR/darwin_linker_stubs.c" -o "$STUBS_O"

link_tool() {
    local tool=$1
    local obj=$2
    local lib=$3
    echo "--- Linking $tool ---"
    
    # Locate the main object and the required library
    local tool_obj=$(find . -name "$obj" | head -n 1)
    local tool_lib=$(find . -name "$lib" | head -n 1)
    
    if [ -n "$tool_obj" ] && [ -n "$tool_lib" ]; then
        gcc -g -O2 -o "$SRC_DIR/$tool" "$tool_obj" "$STUBS_O" "$tool_lib"
        if [ -x "$SRC_DIR/$tool" ]; then
            echo "Successfully built $tool"
        fi
    else
        echo "Skipping $tool: components not found (run make first)"
    fi
}

# Link the core suite
link_tool "gettext" "gettext-gettext.o" "libgrtsrc.a"
link_tool "msgfmt" "msgfmt-msgfmt.o" "libgettextsrc.a"
link_tool "xgettext" "xgettext-xgettext.o" "libgettextsrc.a"
link_tool "msgmerge" "msgmerge-msgmerge.o" "libgettextsrc.a"
link_tool "msginit" "msginit-msginit.o" "libgettextsrc.a"

echo "--- Tools check ---"
[ -f "$SRC_DIR/msgfmt" ] && "$SRC_DIR/msgfmt" --version | head -n 1

