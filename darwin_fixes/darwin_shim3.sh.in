cat > darwin_shim.h <<EOF
#ifndef DARWIN_SHIM_H
#define DARWIN_SHIM_H

#include <stddef.h>
#include <stdlib.h>
#include <string.h>
#include <stdbool.h>
#include <fcntl.h>
#include <stdio.h>
#include <stdarg.h>

#ifdef __cplusplus
extern "C" {
#endif

/* Gnulib Memory Wrappers */
#ifndef _XMALLOC_SHIM_DEFINED
#define _XMALLOC_SHIM_DEFINED
static inline void *xmalloc(size_t n) { 
    void *p = malloc(n); if (!p && n) abort(); return p; 
}
static inline void *xrealloc(void *p, size_t n) { 
    void *r = realloc(p, n); if (!r && n) abort(); return r; 
}
#define XNMALLOC(n, t) ((t *) xmalloc ((n) * sizeof (t)))
#endif

/* --- LINKER STUBS FOR MISSING GNULIB SYMBOLS --- */
/* We define these as static or weak so they satisfy the linker */

const char *program_name = "gettext";

static inline void set_program_name(const char *name) { program_name = name; }
static inline void close_stdout(void) { fflush(stdout); }
static inline void xalloc_die(void) { abort(); }
static inline char *last_component(char const *name) {
    char *p = strrchr(name, '/');
    return p ? p + 1 : (char *) name;
}

/* Variadic error stub */
static inline void error(int status, int errnum, const char *format, ...) {
    va_list ap;
    va_start(ap, format);
    vfprintf(stderr, format, ap);
    va_end(ap);
    if (status) exit(status);
}

/* Stubs for complex Gnulib options logic */
static inline void _gl_start_options() {}
static inline int get_next_option() { return -1; }
static inline const char *proper_name(const char *name) { return name; }
int fzprintf (FILE *stream, const char *format, ...);

/* Basic Darwin Environment */
#ifndef __environ
# include <crt_externs.h>
# define environ (*_NSGetEnviron())
#endif

#ifdef __cplusplus
}
#endif

#endif /* DARWIN_SHIM_H */
EOF

