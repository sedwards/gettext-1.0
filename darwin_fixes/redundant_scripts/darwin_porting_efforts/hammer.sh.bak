 export PATH="/Users/sedwards/gtk/bin:$PATH"
export M4="/Users/sedwards/gtk/bin/m4"
export ROOT_DIR=$(pwd)

# 1. Rebuild aclocal.m4 using absolute paths for EVERY macro source
# We include your prefix's aclocal dir to find Libtool
aclocal --force -I "$ROOT_DIR/m4" \
                -I "$ROOT_DIR/gnulib-m4" \
                -I "$ROOT_DIR/gettext-tools/gnulib-m4" \
                -I "/Users/sedwards/gtk/share/aclocal"

# 2. Re-run autoconf to update the configure script with these macros
autoconf --force

# 3. Now run automake - it should now recognize the GL_ and LIBTOOL macros
automake --add-missing --copy --force-missing

